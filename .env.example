# ─────────────────────────────────────────────────────────────
#  VoiceClone Shield — Environment Variables
#  Copy to .env and fill your keys
# ─────────────────────────────────────────────────────────────

# IBM Watsonx AI (get from cloud.ibm.com)
IBM_WATSONX_API_KEY=your_ibm_watsonx_api_key_here
IBM_WATSONX_PROJECT_ID=your_project_id_here
IBM_WATSONX_URL=https://us-south.ml.cloud.ibm.com

# IBM Watson Speech-to-Text (optional)
IBM_WATSON_STT_API_KEY=your_watson_stt_key_here
IBM_WATSON_STT_URL=https://api.us-south.speech-to-text.watson.cloud.ibm.com

# Self-collect fake voices (optional — only if generating your own)
GOOGLE_APPLICATION_CREDENTIALS=path/to/google_service_account.json
ELEVENLABS_API_KEY=your_elevenlabs_key_here

# App settings
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DEBUG=True

# Model checkpoint path
MODEL_CHECKPOINT=backend/training/checkpoints/best_model.pt

# Detection thresholds
CLONE_THRESHOLD=0.72
LIVENESS_THRESHOLD=0.45
SIMILARITY_THRESHOLD=0.85
